#include <iostream>
#include <vector>
#include <algorithm> // Required for std::sort and std::binary_search

// Function to perform binary search iteratively
int binarySearch(const std::vector<int>& arr, int target) {
    int left = 0;
    int right = arr.size() - 1;

    while (left <= right) {
        // Calculate the middle index to avoid potential overflow with (left+right)/2
        int mid = left + (right - left) / 2;

        // Check if the target is present at the middle
        if (arr[mid] == target) {
            return mid;
        }

        // If target is greater, ignore the left half
        if (arr[mid] < target) {
            left = mid + 1;
        }
        // If target is smaller, ignore the right half
        else {
            right = mid - 1;
        }
    }

    // If the loop finishes, the element was not in the array
    return -1;
}

int main() {
    std::vector<int> numbers = {2, 5, 8, 12, 16, 23, 38, 56, 72, 91};
    int target = 23;

    // The array is already sorted, which is essential for binary search.
    // If not sorted, you could use std::sort(numbers.begin(), numbers.end());

    int result_index = binarySearch(numbers, target);

    if (result_index != -1) {
        std::cout << "Element " << target << " found at index " << result_index << "." << std::endl;
    } else {
        std::cout << "Element " << target << " not found in the array." << std::endl;
    }

    // Example using the C++ STL built-in function
    if (std::binary_search(numbers.begin(), numbers.end(), target)) {
        std::cout << "STL binary_search confirms that " << target << " is present." << std::endl;
    }

    return 0;
}
