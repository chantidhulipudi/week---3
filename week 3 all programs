#include <iostream>
#include <string>

using namespace std;

// Class definition
class Car {
public: // Access specifier - members can be accessed from outside the class
    string brand;   // Attribute (data member)
    string model;   // Attribute
    int year;      // Attribute

    // Member function (method) defined inside the class
    void displayDetails() {
        cout << "Brand: " << brand << ", Model: " << model << ", Year: " << year << endl;
    }
};

int main() {
    // Create an object of the Car class
    Car carObj1;

    // Access attributes and set values using the dot operator
    carObj1.brand = "BMW";
    carObj1.model = "X5";
    carObj1.year = 1999;

    // Call the member function to display details
    carObj1.displayDetails();

    // Create another object of the same class
    Car carObj2;

    // Access attributes and set values for the second object
    carObj2.brand = "Ford";
    carObj2.model = "Mustang";
    carObj2.year = 1969;

    // Call the member function for the second object
    carObj2.displayDetails();

    return 0;
}
2)write a c++ program to code c++ constructor and destructor
#include <iostream>
using namespace std;

class MyClass {
public:
    // Constructor
    // It has the same name as the class and no return type.
    MyClass() {
        cout << "Constructor called: Object is being created" << endl;
    }

    // Destructor
    // It has the same name as the class, prefixed with a tilde (~),
    // and cannot return a value or take any parameters.
    ~MyClass() {
        cout << "Destructor called: Object is being deleted" << endl;
    }

    // A simple member function
    void displayMessage() {
        cout << "Inside the displayMessage function" << endl;
    }
};

int main() {
    // Creating an object of MyClass
    // The constructor is automatically called when the object 'obj' is created.
    MyClass obj;

    // Calling a member function
    obj.displayMessage();

    // The destructor is automatically called when the object 'obj' goes out of scope,
    // which happens at the end of the main function in this case.
    return 0;
}
3) write a c++ program to code c++ linear search
#include <iostream>

// Function to perform linear search
int linearSearch(int arr[], int size, int target) {
    // Iterate through the array elements from the first (index 0) to the last
    for (int i = 0; i < size; i++) {
        // Check if the current element matches the target value
        if (arr[i] == target) {
            return i; // Return the index if a match is found
        }
    }
    return -1; // Return -1 if the target is not found in the array
}

int main() {
    // Example array
    int array[] = {12, 9, 37, 86, 2, 17, 5};
    // Calculate the size of the array
    int n = sizeof(array) / sizeof(array[0]);
    // The value to search for
    int target = 17;

    // Call the linear search function
    int result = linearSearch(array, n, target);

    // Display the result
    if (result == -1) {
        std::cout << "Element not found" << std::endl;
    } else {
        std::cout << "Element found at index: " << result << std::endl;
    }

    return 0;
}

4) write a c++ program to occurance of search key
#include <iostream>

using namespace std;

/**
 * Counts the number of occurrences of a search key in an array.
 * 
 * @param arr The array of integers.
 * @param n The size of the array.
 * @param key The value to search for.
 * @return The number of times the key appears in the array.
 */
int countOccurrences(int arr[], int n, int key) {
    int count = 0;
    // Iterate through the array
    for (int i = 0; i < n; i++) {
        // If the current element matches the key, increment the counter
        if (arr[i] == key) {
            count++;
        }
    }
    return count;
}

int main() {
    int arr[] = {10, 20, 10, 30, 40, 10, 50, 20};
    int n = sizeof(arr) / sizeof(arr[0]);
    int searchKey = 10;

    // Call the function to count occurrences
    int occurrences = countOccurrences(arr, n, searchKey);

    // Output the result
    cout << "The search key " << searchKey << " appears " << occurrences << " times in the array." << endl;

    return 0;
}
